/*国王将金币作为工资，发放给忠诚的骑士。第一天，骑士收到一枚金币；之后两天（第二天和第三天），每天收到两枚金币；之后三天（第四、五、六天），每天收到三枚金币；之后四天（第七、八、九、十天），每天收到四枚金币……；这种工资发放模式会一直这样延续下去：当连续 n 天每天收到 n 枚金币后，骑士会在之后的连续 n+1 天里，每天收到 n+1 枚金币。

请计算在前 k 天里，骑士一共获得了多少金币。

输入格式
一个正整数 k，表示发放金币的天数。

输出格式
一个正整数，即骑士收到的金币数。*/


#include <iostream>
using namespace std;

int main() {
    int k;
    cin >> k;
    
    int total = 0;  // 总金币
    int days = 0;   // 已经过了多少天
    int cnt = 1;    // 当前阶段：每天发 cnt 个，持续 cnt 天
    
    while (days < k) {
        // 本轮要发几天：最多发 cnt 天，但不能超过剩余天数
        int need = cnt;
        if (days + cnt > k) {
            need = k - days;
        }
        
        total += cnt * need;  // 累加这一阶段的金币
        days += need;         // 累加天数
        cnt++;                // 进入下一阶段
    }
    
    cout << total << endl;
    return 0;
}
